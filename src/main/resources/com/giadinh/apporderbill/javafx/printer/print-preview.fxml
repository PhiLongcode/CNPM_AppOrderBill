<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.giadinh.apporderbill.javafx.printer.PrintPreviewController"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- Top: Header and controls -->
    <top>
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15;">
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="📄 Xem trước in" 
                       style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
                <Separator orientation="VERTICAL" prefHeight="30"/>
                <Label fx:id="paperSizeLabel" text="Khổ giấy: 80mm"/>
                <Label fx:id="charsPerLineLabel" text="Số ký tự/dòng: 42"/>
                <Label fx:id="fontSizeLabel" text="Font: 10pt"/>
            </HBox>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Button text="🔍 Phóng to" onAction="#onZoomIn" 
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                <Button text="🔍 Thu nhỏ" onAction="#onZoomOut"
                        style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                <Button text="📏 Kích thước thực" onAction="#onActualSize"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                <Button text="↻ Reset" onAction="#onResetZoom"
                        style="-fx-background-color: #757575; -fx-text-fill: white;"/>
                <Separator orientation="VERTICAL" prefHeight="25"/>
                <Label text="Tỷ lệ:"/>
                <Label fx:id="zoomLabel" text="100%" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>
        </VBox>
    </top>
    
    <!-- Center: Paper preview -->
    <center>
        <ScrollPane fx:id="previewScrollPane" fitToWidth="false" fitToHeight="true"
                    style="-fx-background-color: #d0d0d0; -fx-padding: 20;">
            <VBox fx:id="previewContainer" alignment="CENTER" spacing="15" 
                  style="-fx-padding: 40;">
                <!-- Paper representation with ruler/scale -->
                <VBox spacing="5" alignment="CENTER">
                    <!-- Top ruler (optional, shows scale) -->
                    <HBox alignment="CENTER" spacing="5">
                        <Label fx:id="scaleLabel" text="1:1 (Kích thước thực tế)" 
                               style="-fx-font-size: 11px; -fx-text-fill: #666;"/>
                    </HBox>
                    
                    <!-- Paper box -->
                    <VBox fx:id="paperBox" alignment="TOP_LEFT"
                          style="-fx-background-color: white; -fx-border-color: #000; -fx-border-width: 2; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 15, 0, 0, 3);">
                    <TextArea fx:id="previewTextArea"
                              editable="false"
                              wrapText="false"
                              style="-fx-font-family: 'Courier New', 'Consolas', monospace; -fx-background-color: white; -fx-border-color: transparent; -fx-padding: 5; -fx-control-inner-background: white;"/>
                    </VBox>
                    
                    <!-- Bottom info -->
                    <HBox spacing="10" alignment="CENTER">
                        <Label fx:id="paperWidthLabel" text="Chiều rộng: 80mm" 
                               style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                        <Separator orientation="VERTICAL" prefHeight="15"/>
                        <Label fx:id="paperHeightLabel" text="Chiều cao: ~300mm" 
                               style="-fx-font-size: 11px; -fx-text-fill: #555;"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
    
    <!-- Bottom: Footer info -->
    <bottom>
        <HBox spacing="10" alignment="CENTER" style="-fx-background-color: white; -fx-padding: 10;">
            <Label text="💡 Tip: Kích thước hiển thị tương đối, có thể zoom để xem chi tiết"/>
            <Separator orientation="VERTICAL" prefHeight="20"/>
            <Button text="Đóng" onAction="#onClose" 
                    style="-fx-background-color: #757575; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>

