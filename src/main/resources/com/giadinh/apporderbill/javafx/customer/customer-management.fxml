<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.giadinh.apporderbill.javafx.customer.CustomerManagementController">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <top>
        <VBox spacing="8" style="-fx-padding: 12; -fx-background-color: #1e3a5f;">
            <Label text="Quản lý khách hàng"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Tìm theo tên/sđt..." prefWidth="240"/>
                <Button text="🔍 Tìm"   onAction="#onSearch"
                        style="-fx-background-color:#2196F3;-fx-text-fill:white;"/>
                <Button text="🔄 Làm mới" onAction="#onRefresh"
                        style="-fx-background-color:#607D8B;-fx-text-fill:white;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="➕ Thêm" onAction="#onAdd"
                        style="-fx-background-color:#4CAF50;-fx-text-fill:white;"/>
                <Button text="✏️ Sửa"  onAction="#onEdit"
                        style="-fx-background-color:#FF9800;-fx-text-fill:white;"/>
                <Button text="🗑 Xóa"  onAction="#onDelete"
                        style="-fx-background-color:#F44336;-fx-text-fill:white;"/>
            </HBox>
            <HBox spacing="8" alignment="CENTER_LEFT">
                <Label text="Cấu hình tích điểm:"
                       style="-fx-text-fill:#E3F2FD; -fx-font-weight:bold;"/>
                <TextField fx:id="earnUnitAmountField" promptText="Tiền tích (VD: 10000)" prefWidth="120"/>
                <Label fx:id="earnUnitInfoLabel" text="ⓘ" style="-fx-text-fill:#BBDEFB; -fx-font-weight:bold;"/>
                <TextField fx:id="pointsPerUnitField" promptText="Điểm nhận" prefWidth="90"/>
                <Label fx:id="pointsPerUnitInfoLabel" text="ⓘ" style="-fx-text-fill:#BBDEFB; -fx-font-weight:bold;"/>
                <TextField fx:id="redeemPointsRequiredField" promptText="Điểm đổi" prefWidth="90"/>
                <Label fx:id="redeemPointsInfoLabel" text="ⓘ" style="-fx-text-fill:#BBDEFB; -fx-font-weight:bold;"/>
                <TextField fx:id="redeemValueField" promptText="Giá trị đổi" prefWidth="120"/>
                <Label fx:id="redeemValueInfoLabel" text="ⓘ" style="-fx-text-fill:#BBDEFB; -fx-font-weight:bold;"/>
                <Button text="💾 Lưu cấu hình" onAction="#onSaveLoyaltyConfig"
                        style="-fx-background-color:#43A047;-fx-text-fill:white;"/>
            </HBox>
        </VBox>
    </top>

    <!-- ── Main area: customer list  |  point history ─────────────────── -->
    <center>
        <SplitPane dividerPositions="0.55">

            <!-- Left: danh sách khách hàng -->
            <VBox spacing="0" SplitPane.resizableWithParent="true">
                <Label text="Danh sách khách hàng"
                       style="-fx-padding:8 12; -fx-font-weight:bold; -fx-background-color:#f5f5f5; -fx-border-color:#ddd; -fx-border-width: 0 0 1 0;"/>
                <TableView fx:id="customerTable" VBox.vgrow="ALWAYS"
                           onMouseClicked="#onCustomerSelected">
                    <columns>
                        <TableColumn fx:id="idColumn"     text="ID"       prefWidth="60"/>
                        <TableColumn fx:id="nameColumn"   text="Tên khách" prefWidth="200"/>
                        <TableColumn fx:id="phoneColumn"  text="SĐT"      prefWidth="140"/>
                        <TableColumn fx:id="pointsColumn" text="Điểm tích lũy" prefWidth="120"/>
                    </columns>
                    <placeholder>
                        <Label text="Chưa có khách hàng nào"/>
                    </placeholder>
                </TableView>
            </VBox>

            <!-- Right: lịch sử điểm của khách đang chọn -->
            <VBox spacing="0" SplitPane.resizableWithParent="true">
                <HBox alignment="CENTER_LEFT" spacing="10"
                      style="-fx-padding:8 12; -fx-background-color:#1e3a5f;">
                    <Label text="🎯 Lịch sử điểm —"
                           style="-fx-text-fill:white; -fx-font-weight:bold;"/>
                    <Label fx:id="historyCustomerLabel" text="(chọn khách để xem)"
                           style="-fx-text-fill:#90CAF9; -fx-font-weight:bold;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="historyBalanceLabel" text=""
                           style="-fx-text-fill:#A5D6A7; -fx-font-weight:bold;"/>
                </HBox>

                <TableView fx:id="pointHistoryTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="txDateColumn"    text="Thời gian"    prefWidth="140"/>
                        <TableColumn fx:id="txTypeColumn"    text="Loại"         prefWidth="90"/>
                        <TableColumn fx:id="txDeltaColumn"   text="Thay đổi"    prefWidth="90"/>
                        <TableColumn fx:id="txBalanceColumn" text="Còn lại"      prefWidth="90"/>
                        <TableColumn fx:id="txNoteColumn"    text="Ghi chú"      prefWidth="200"/>
                        <TableColumn fx:id="txOrderColumn"   text="Đơn hàng"     prefWidth="130"/>
                    </columns>
                    <placeholder>
                        <Label text="Chưa có giao dịch điểm nào"/>
                    </placeholder>
                </TableView>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
