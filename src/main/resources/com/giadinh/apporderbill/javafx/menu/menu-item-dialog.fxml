<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>

<DialogPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.giadinh.apporderbill.javafx.menu.MenuItemDialogController"
            prefWidth="580" minHeight="650"
            styleClass="menu-item-dialog"
            stylesheets="@menu-item-dialog.css">

    <content>
        <ScrollPane fitToWidth="true" styleClass="main-scroll">
            <VBox spacing="16" styleClass="main-content">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Section 1: Thông tin chung -->
                <VBox styleClass="section-card" spacing="10">
                    <Label text="📋 Thông tin chung" styleClass="section-title"/>
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <padding>
                            <Insets top="8"/>
                        </padding>

                        <Label text="Tên món:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="nameField" prefWidth="280" promptText="Nhập tên món"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                        <Label text="Danh mục:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="categoryField" prefWidth="280" promptText="VD: Đồ uống, Đồ ăn..."
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Hình ảnh:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <HBox spacing="8" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <TextField fx:id="imageUrlField" HBox.hgrow="ALWAYS" promptText="Đường dẫn hoặc URL hình ảnh"/>
                            <Button fx:id="browseImageBtn" text="Chọn..." onAction="#onBrowseImage"/>
                        </HBox>
                    </GridPane>
                </VBox>

                <!-- Section 2: Giá & lợi nhuận -->
                <VBox styleClass="section-card" spacing="10">
                    <Label text="💰 Giá &amp; lợi nhuận" styleClass="section-title"/>
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <padding>
                            <Insets top="8"/>
                        </padding>

                        <Label text="Giá bán (VNĐ):" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="priceField" prefWidth="150" promptText="0"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <tooltip>
                                <Tooltip text="Giá bán cho đơn vị cơ bản"/>
                            </tooltip>
                        </TextField>

                        <Label text="Giá vốn (VNĐ):" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="costPriceField" prefWidth="150" promptText="0"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <tooltip>
                                <Tooltip text="Giá vốn dùng để tính lợi nhuận"/>
                            </tooltip>
                        </TextField>

                        <Label text="SKU:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <TextField fx:id="skuField" prefWidth="150" promptText="Để trống sẽ tự sinh"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    </GridPane>
                </VBox>

                <!-- Section 3: Quản lý tồn kho -->
                <VBox styleClass="section-card" spacing="10">
                    <Label text="📦 Quản lý tồn kho" styleClass="section-title"/>
                    <GridPane hgap="12" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="100"/>
                            <ColumnConstraints hgrow="ALWAYS"/>
                        </columnConstraints>
                        <padding>
                            <Insets top="8"/>
                        </padding>

                        <Label text="Đơn vị cơ bản:" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <TextField fx:id="baseUnitField" prefWidth="100" promptText="unit"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <tooltip>
                                <Tooltip text="Đơn vị cơ bản dùng để tính tồn kho"/>
                            </tooltip>
                        </TextField>

                        <CheckBox fx:id="stockTrackedCheck" text="Quản lý tồn kho"
                                  GridPane.columnIndex="0" GridPane.rowIndex="1" GridPane.columnSpan="2">
                            <tooltip>
                                <Tooltip text="Bật để quản lý tồn kho cho sản phẩm này"/>
                            </tooltip>
                        </CheckBox>
                    </GridPane>

                    <!-- Stock quantity fields -->
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="Tồn hiện tại:" styleClass="field-label"/>
                            <TextField fx:id="stockQtyField" prefWidth="90" promptText="0">
                                <tooltip>
                                    <Tooltip text="Số lượng tồn kho hiện tại"/>
                                </tooltip>
                            </TextField>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Tồn tối thiểu:" styleClass="field-label"/>
                            <TextField fx:id="stockMinField" prefWidth="90" promptText="0">
                                <tooltip>
                                    <Tooltip text="Cảnh báo khi tồn kho dưới mức này"/>
                                </tooltip>
                            </TextField>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Tồn tối đa:" styleClass="field-label"/>
                            <TextField fx:id="stockMaxField" prefWidth="90" promptText="0">
                                <tooltip>
                                    <Tooltip text="Giới hạn tồn kho tối đa"/>
                                </tooltip>
                            </TextField>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Section 4: Đơn vị tính / Quy đổi -->
              

            </VBox>
        </ScrollPane>
    </content>

    <buttonTypes>
        <ButtonType fx:constant="CANCEL"/>
        <ButtonType fx:id="saveButtonType" text="Lưu" buttonData="OK_DONE"/>
    </buttonTypes>

</DialogPane>
