<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<fx:root type="javafx.scene.control.DialogPane" xmlns:fx="http://javafx.com/fxml"
         stylesheets="@checkout-style.css">
    <content>
        <VBox spacing="0" styleClass="checkout-container">
            <!-- Header with Order Info -->
            <HBox styleClass="header-section" alignment="CENTER" spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label fx:id="orderTitleLabel" text="Thanh toán #1-7" styleClass="order-title"/>
                    <Label fx:id="orderInfoLabel" text="Bàn 9 / Lầu 2" styleClass="order-info"/>
                </VBox>
                <Label fx:id="dateTimeLabel" text="07/12/2025 09:38" styleClass="datetime-label"/>
            </HBox>
            
            <!-- Main Content Area - 2 Column Layout with Resizable Divider -->
            <SplitPane dividerPositions="0.58" styleClass="content-section" VBox.vgrow="ALWAYS">
                <!-- Left Column: Order Items List -->
                <VBox spacing="8" styleClass="items-section" SplitPane.resizableWithParent="true">
                    <Label text="Danh sách món" styleClass="section-title"/>
                    <TableView fx:id="itemsTableView" styleClass="items-table" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="itemIndexColumn" text="STT" prefWidth="50" minWidth="40"
                                         styleClass="center-column"/>
                            <TableColumn fx:id="itemNameColumn" text="Tên món" prefWidth="150" minWidth="120"/>
                            <TableColumn fx:id="itemQuantityColumn" text="SL" prefWidth="50" minWidth="40"
                                         styleClass="center-column"/>
                            <TableColumn fx:id="itemPriceColumn" text="Đơn giá" prefWidth="85" minWidth="70"
                                         styleClass="right-column"/>
                            <TableColumn fx:id="itemDiscountPercentColumn" text="Giảm giá (%)" prefWidth="90" minWidth="80"
                                         styleClass="center-column"/>
                            <TableColumn fx:id="itemDiscountAmountColumn" text="Giá giảm" prefWidth="85" minWidth="70"
                                         styleClass="right-column"/>
                            <TableColumn fx:id="itemTotalColumn" text="Thành tiền" prefWidth="85" minWidth="70"
                                         styleClass="right-column"/>
                        </columns>
                        <placeholder>
                            <Label text="Không có món nào"/>
                        </placeholder>
                    </TableView>
                </VBox>
                
                <!-- Right Column: Payment Information with Scroll -->
                <ScrollPane fitToWidth="true" styleClass="payment-scroll" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                            SplitPane.resizableWithParent="true">
                    <VBox spacing="15" styleClass="payment-info-section">
                        <Label text="Thông tin thanh toán" styleClass="section-title"/>
                        
                        <!-- Payment Summary -->
                        <VBox spacing="15" styleClass="payment-summary">
                            <!-- Tổng tiền -->
                            <VBox spacing="8" styleClass="summary-item">
                                <Label text="Tổng tiền hàng" styleClass="summary-label-small"/>
                                <HBox spacing="10" alignment="CENTER_LEFT">
                                    <Label fx:id="itemCountLabel" text="0" styleClass="item-badge"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="totalAmountLabel" text="0" styleClass="summary-amount-big"/>
                                </HBox>
                            </VBox>
                            
                            <Separator/>
                            
                            <!-- Giảm giá -->
                            <VBox spacing="8" styleClass="summary-item">
                                <Label text="Giảm giá" styleClass="summary-label-small"/>
                                <TextField fx:id="discountField" text="0" styleClass="discount-input-large" 
                                           promptText="Nhập số tiền giảm" maxWidth="Infinity"/>
                            </VBox>
                            
                            <Separator/>
                            
                            <!-- Khách cần trả -->
                            <VBox spacing="8" styleClass="summary-item final-item">
                                <Label text="Khách cần trả" styleClass="final-label-big"/>
                                <Label fx:id="finalAmountLabel" text="0" styleClass="final-amount-huge"/>
                            </VBox>
                            
                            <Separator/>
                            
                            <!-- Tiền khách đưa -->
                            <VBox spacing="8" styleClass="summary-item">
                                <Label text="Tiền khách đưa" styleClass="summary-label-small"/>
                                <TextField fx:id="paidAmountField" text="" styleClass="paid-input-large" 
                                           promptText="Nhập số tiền khách đưa" maxWidth="Infinity"/>
                            </VBox>
                            
                            <!-- Tiền thối -->
                            <VBox spacing="8" styleClass="summary-item">
                                <Label text="Tiền thối lại" styleClass="summary-label-small"/>
                                <Label fx:id="changeAmountLabel" text="0" styleClass="change-amount-big"/>
                            </VBox>
                            
                            <Separator/>

                            <!-- Customer Section -->
                            <VBox spacing="8" styleClass="summary-item" fx:id="customerSection">
                                <Label text="Khách hàng" styleClass="section-title-small"/>
                                <HBox spacing="6" alignment="CENTER_LEFT">
                                    <TextField fx:id="customerPhoneField" promptText="Nhập số điện thoại..."
                                               HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                    <Button fx:id="searchCustomerBtn" text="🔍 Tìm" onAction="#onSearchCustomer"
                                            style="-fx-background-color: #1e3a5f; -fx-text-fill: white; -fx-cursor: hand;"/>
                                </HBox>
                                <VBox fx:id="customerInfoBox" spacing="4" managed="false" visible="false"
                                      style="-fx-background-color: #f0f7ff; -fx-padding: 8; -fx-background-radius: 6;">
                                    <HBox spacing="8">
                                        <Label text="👤" style="-fx-font-size:14;"/>
                                        <Label fx:id="customerNameLabel" text="" style="-fx-font-weight:bold;"/>
                                    </HBox>
                                    <HBox spacing="8">
                                        <Label text="🎯 Điểm tích lũy:" style="-fx-text-fill:#555;"/>
                                        <Label fx:id="customerPointsLabel" text="0 điểm" style="-fx-font-weight:bold;-fx-text-fill:#1e3a5f;"/>
                                    </HBox>
                                </VBox>
                                <!-- Thêm khách mới nếu chưa có -->
                                <VBox fx:id="newCustomerBox" spacing="6" managed="false" visible="false">
                                    <Label text="Khách mới — nhập tên:" style="-fx-font-size:11; -fx-text-fill:#777;"/>
                                    <HBox spacing="6">
                                        <TextField fx:id="newCustomerNameField" promptText="Tên khách hàng (tuỳ chọn)"
                                                   HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                                        <Button fx:id="addCustomerBtn" text="+ Thêm" onAction="#onAddCustomer"
                                                style="-fx-background-color:#4CAF50;-fx-text-fill:white;-fx-cursor:hand;"/>
                                    </HBox>
                                </VBox>
                                <!-- Đổi điểm -->
                                <VBox fx:id="redeemPointsBox" spacing="6" managed="false" visible="false"
                                      style="-fx-background-color:#fff8e1;-fx-padding:8;-fx-background-radius:6;">
                                    <Label text="🎁 Sử dụng điểm tích lũy" style="-fx-font-weight:bold;-fx-text-fill:#e65100;"/>
                                    <HBox spacing="6" alignment="CENTER_LEFT">
                                        <Label text="Số điểm muốn dùng:" style="-fx-text-fill:#555;"/>
                                        <TextField fx:id="redeemPointsField" promptText="0" prefWidth="80"
                                                   onKeyReleased="#onRedeemPointsChanged"/>
                                        <Label fx:id="redeemDiscountLabel" text="→ 0 VNĐ"
                                               style="-fx-text-fill:#e65100;-fx-font-weight:bold;"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <Separator/>
                            
                            <!-- Payment Method Section -->
                            <VBox spacing="10" styleClass="payment-method-section">
                                <Label text="Hình thức thanh toán" styleClass="section-title-small"/>
                                <VBox spacing="8">
                                    <ToggleButton fx:id="cashButton" text="💵 Tiền mặt" styleClass="payment-btn-block" 
                                                  selected="true" maxWidth="Infinity">
                                        <toggleGroup>
                                            <ToggleGroup fx:id="paymentMethodGroup"/>
                                        </toggleGroup>
                                    </ToggleButton>
                                    <ToggleButton fx:id="transferButton" text="🏦 Chuyển khoản" 
                                                  styleClass="payment-btn-block" maxWidth="Infinity"
                                                  toggleGroup="$paymentMethodGroup"/>
                                    <ToggleButton fx:id="cardButton" text="💳 Thẻ" 
                                                  styleClass="payment-btn-block" maxWidth="Infinity"
                                                  toggleGroup="$paymentMethodGroup"/>
                                </VBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </SplitPane>
            
            <!-- Action Buttons - Simplified -->
            <HBox spacing="15" styleClass="action-section" alignment="CENTER">
                <Button fx:id="cancelButton" text="Hủy (ESC)" styleClass="cancel-btn-large"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="confirmButton" text="THANH TOÁN" styleClass="confirm-btn-large"/>
            </HBox>
        </VBox>
    </content>
</fx:root>
