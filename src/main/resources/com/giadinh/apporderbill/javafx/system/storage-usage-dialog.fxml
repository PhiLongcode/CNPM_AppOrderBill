<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<DialogPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.giadinh.apporderbill.javafx.system.StorageUsageDialogController"
            prefWidth="600" prefHeight="500">

    <content>
        <VBox spacing="20" style="-fx-background-color: white;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <!-- Header -->
            <Label text="💾 Kiểm tra dung lượng sử dụng" 
                   style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            
            <!-- Database Info Section -->
            <VBox spacing="10" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-background-radius: 5;">
                <Label text="📊 Thông tin Database (pos.db)" 
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                
                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="150" prefWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    
                    <Label text="Đường dẫn:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="databasePathLabel" text="Đang tải..." 
                           wrapText="true" GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-text-fill: #666;"/>
                    
                    <Label text="Dung lượng file:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <HBox spacing="5" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="1">
                        <Label fx:id="databaseSizeLabel" text="0 MB" 
                               style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                        <Label fx:id="databaseSizeBytesLabel" text="(0 bytes)" 
                               style="-fx-font-size: 11px; -fx-text-fill: #999;"/>
                    </HBox>
                    
                    <Label text="Tên file:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="databaseFileNameLabel" text="pos.db" 
                           GridPane.columnIndex="1" GridPane.rowIndex="2"
                           style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
                </GridPane>
            </VBox>
            
            <!-- Disk Space Section -->
            <VBox spacing="10" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-background-radius: 5;">
                <Label text="💿 Thông tin ổ đĩa" 
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                
                <GridPane hgap="15" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="150" prefWidth="150"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    
                    <Label text="Dung lượng còn trống:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="availableSpaceLabel" text="0 MB" 
                           GridPane.columnIndex="1" GridPane.rowIndex="0"
                           style="-fx-font-weight: bold;"/>
                    
                    <Label text="Tổng dung lượng:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="totalSpaceLabel" text="0 MB" 
                           GridPane.columnIndex="1" GridPane.rowIndex="1"
                           style="-fx-text-fill: #666;"/>
                    
                    <Label text="Phần trăm sử dụng:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <HBox spacing="10" alignment="CENTER_LEFT" GridPane.columnIndex="1" GridPane.rowIndex="2">
                        <ProgressBar fx:id="usageProgressBar" prefWidth="200" maxWidth="200"/>
                        <Label fx:id="usagePercentageLabel" text="0%" 
                               style="-fx-font-weight: bold;"/>
                    </HBox>
                </GridPane>
            </VBox>
            
            <!-- Status Section -->
            <VBox spacing="10" style="-fx-background-color: #f9f9f9; -fx-padding: 15; -fx-background-radius: 5;">
                <Label text="⚠️ Trạng thái" 
                       style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label fx:id="statusLabel" text="Đang kiểm tra..." 
                           style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
                </HBox>
                
                <Label fx:id="messageLabel" text="" 
                       wrapText="true" 
                       style="-fx-text-fill: #666; -fx-padding: 10 0 0 0;"/>
            </VBox>
            
            <!-- Refresh Button -->
            <HBox alignment="CENTER" spacing="10">
                <Button fx:id="refreshButton" text="🔄 Làm mới" 
                        onAction="#onRefresh" 
                        style="-fx-padding: 8 20; -fx-font-size: 12px;"/>
            </HBox>
        </VBox>
    </content>
    
    <buttonTypes>
        <ButtonType text="Đóng" buttonData="CANCEL_CLOSE"/>
    </buttonTypes>
</DialogPane>

