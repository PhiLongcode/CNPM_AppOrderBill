<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.giadinh.apporderbill.javafx.dashboard.PaymentDetailDialogController"
      spacing="15" style="-fx-padding: 20;">
    <!-- Header Info -->
    <VBox spacing="5">
        <HBox spacing="10">
            <Label text="Mã hóa đơn:" style="-fx-font-weight: bold;"/>
            <Label fx:id="paymentIdLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Bàn:" style="-fx-font-weight: bold;"/>
            <Label fx:id="tableNumberLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Thời gian:" style="-fx-font-weight: bold;"/>
            <Label fx:id="paidAtLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Phương thức:" style="-fx-font-weight: bold;"/>
            <Label fx:id="paymentMethodLabel"/>
        </HBox>
    </VBox>

    <!-- Items Table -->
    <Label text="Danh sách món ăn:" style="-fx-font-size: 16px; -fx-font-weight: bold;"/>
    <TableView fx:id="itemsTable" prefHeight="250">
        <columns>
            <TableColumn fx:id="itemNameColumn" text="Tên món" prefWidth="200"/>
            <TableColumn fx:id="quantityColumn" text="SL" prefWidth="60"/>
            <TableColumn fx:id="unitColumn" text="ĐV" prefWidth="80"/>
            <TableColumn fx:id="unitPriceColumn" text="Đơn giá" prefWidth="100"/>
            <TableColumn fx:id="discountColumn" text="Giảm giá" prefWidth="80"/>
            <TableColumn fx:id="lineTotalColumn" text="Thành tiền" prefWidth="120"/>
        </columns>
    </TableView>

    <!-- Summary -->
    <VBox spacing="5" style="-fx-background-color: #f5f5f5; -fx-padding: 10; -fx-background-radius: 5;">
        <HBox spacing="10">
            <Label text="Tổng tiền:" style="-fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="totalAmountLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Giảm giá:" style="-fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="discountAmountLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Thành tiền:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="finalAmountLabel" style="-fx-font-size: 14px; -fx-text-fill: #4CAF50;"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Khách đưa:" style="-fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="paidAmountLabel"/>
        </HBox>
        <HBox spacing="10">
            <Label text="Tiền thừa:" style="-fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="changeAmountLabel"/>
        </HBox>
    </VBox>
</VBox>

