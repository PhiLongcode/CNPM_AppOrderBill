<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.giadinh.apporderbill.javafx.dashboard.DashboardController"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- Top: Header và Filter -->
    <top>
        <VBox spacing="10" style="-fx-background-color: #1e3a5f; -fx-padding: 15;">
            <Label text="📊 Thống kê Doanh thu" 
                   style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;"/>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Chế độ:" style="-fx-text-fill: white;"/>
                <ToggleButton fx:id="todayBtn" text="Hôm nay" selected="true"/>
                <ToggleButton fx:id="weekBtn" text="Tuần này"/>
                <ToggleButton fx:id="monthBtn" text="Tháng này"/>
                <ToggleButton fx:id="customBtn" text="Tùy chọn"/>
                
                <Region HBox.hgrow="ALWAYS"/>
                
                <Label text="Từ ngày:" style="-fx-text-fill: white;"/>
                <DatePicker fx:id="startDatePicker" prefWidth="150"/>
                <Label text="Đến ngày:" style="-fx-text-fill: white;"/>
                <DatePicker fx:id="endDatePicker" prefWidth="150"/>
                <Button fx:id="refreshBtn" text="Làm mới" onAction="#onRefreshClick"
                        style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>
    
    <!-- Center: Statistics Cards -->
    <center>
        <ScrollPane fitToWidth="true">
            <VBox spacing="20" style="-fx-padding: 20;">
                <!-- Summary Cards -->
                <HBox spacing="15">
                    <VBox fx:id="totalRevenueCard" spacing="5" 
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
                          prefWidth="300">
                        <Label text="Tổng doanh thu" style="-fx-font-size: 14px; -fx-text-fill: gray;"/>
                        <Label fx:id="totalRevenueLabel" text="0 VNĐ" 
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
                    </VBox>
                    
                    <VBox fx:id="totalBillsCard" spacing="5" 
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
                          prefWidth="300">
                        <Label text="Tổng số bill" style="-fx-font-size: 14px; -fx-text-fill: gray;"/>
                        <Label fx:id="totalBillsLabel" text="0" 
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
                    </VBox>
                    
                    <VBox fx:id="averageBillCard" spacing="5" 
                          style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);"
                          prefWidth="300">
                        <Label text="Trung bình/bill" style="-fx-font-size: 14px; -fx-text-fill: gray;"/>
                        <Label fx:id="averageBillLabel" text="0 VNĐ" 
                               style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
                    </VBox>
                </HBox>
                
                <!-- Daily Revenue Table -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                    <Label text="Chi tiết theo ngày" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <TableView fx:id="dailyRevenueTable" prefHeight="300">
                        <columns>
                            <TableColumn fx:id="dateColumn" text="Ngày" prefWidth="150"/>
                            <TableColumn fx:id="revenueColumn" text="Doanh thu" prefWidth="200"/>
                            <TableColumn fx:id="billsColumn" text="Số bill" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
                
                <!-- Payment History Table with Reprint -->
                <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🧾 Lịch sử hóa đơn" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Từ ngày:"/>
                        <DatePicker fx:id="paymentStartDatePicker" prefWidth="120"/>
                        <Label text="Đến ngày:"/>
                        <DatePicker fx:id="paymentEndDatePicker" prefWidth="120"/>
                        <Button fx:id="loadPaymentsBtn" text="📥 Tải" onAction="#onLoadPaymentsClick"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                        <Button fx:id="refreshPaymentsBtn" text="🔄 Làm mới" onAction="#onRefreshPaymentsClick"
                                style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
                    </HBox>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button fx:id="viewDetailBtn" text="👁 Xem chi tiết" onAction="#onViewDetailClick"
                                style="-fx-background-color: #4CAF50; -fx-text-fill: white;"/>
                        <Button fx:id="deleteSelectedBtn" text="🗑 Xóa đã chọn" onAction="#onDeleteSelectedClick"
                                style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                        <Button fx:id="deleteByDateRangeBtn" text="🗑 Xóa theo ngày" onAction="#onDeleteByDateRangeClick"
                                style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
                    </HBox>
                    <TableView fx:id="paymentsTable" prefHeight="250">
                        <columns>
                            <TableColumn fx:id="paymentSelectColumn" text="Chọn" prefWidth="50"/>
                            <TableColumn fx:id="paymentIdColumn" text="Mã HĐ" prefWidth="80"/>
                            <TableColumn fx:id="paymentTableColumn" text="Bàn" prefWidth="80"/>
                            <TableColumn fx:id="paymentAmountColumn" text="Số tiền" prefWidth="150"/>
                            <TableColumn fx:id="paymentMethodColumn" text="Phương thức" prefWidth="120"/>
                            <TableColumn fx:id="paymentTimeColumn" text="Thời gian" prefWidth="180"/>
                            <TableColumn fx:id="paymentActionColumn" text="Thao tác" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

